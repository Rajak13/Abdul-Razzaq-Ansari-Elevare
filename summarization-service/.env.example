# PEGASUS Model Configuration
# Using google/pegasus-arxiv - optimized for academic and scientific content
MODEL_NAME=google/pegasus-arxiv

# Model Parameters
MAX_SUMMARY_LENGTH=128
MIN_SUMMARY_LENGTH=30

# Chunking Configuration (PEGASUS max is 512 tokens)
MAX_CHUNK_SIZE=400
CHUNK_OVERLAP=50

# Cache Configuration
CACHE_SIZE=1000
CACHE_TTL=3600

# Performance Configuration
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=300
TORCH_THREADS=4

# Optional: Enable GPU (requires CUDA)
# ENABLE_GPU=true
