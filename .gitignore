# Allow frontend public images
!frontend/public/**/*.jpg
!frontend/public/**/*.jpeg
!frontend/public/**/*.png
!frontend/public/**/*.gif
!frontend/public/**/*.svg
# Block all other images
*.jpg
*.jpeg
*.png
*.gif
*.pdf
*.doc
*.docx

