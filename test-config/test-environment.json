{
  "environment": {
    "name": "e2e-test",
    "description": "End-to-end testing environment for PEGASUS summarization integration",
    "services": {
      "database": {
        "host": "localhost",
        "port": 5433,
        "name": "elevare_test",
        "user": "test_user",
        "password": "test_password"
      },
      "backend": {
        "host": "localhost",
        "port": 3001,
        "healthEndpoint": "/health"
      },
      "summarization": {
        "host": "localhost",
        "port": 8001,
        "healthEndpoint": "/health",
        "modelName": "google/pegasus-xsum",
        "maxInputLength": 1000,
        "cacheSize": 10
      },
      "frontend": {
        "host": "localhost",
        "port": 3000,
        "healthEndpoint": "/"
      }
    }
  },
  "testConfiguration": {
    "timeouts": {
      "serviceStartup": 60000,
      "modelLoading": 120000,
      "summarization": 30000,
      "longSummarization": 60000,
      "networkRequest": 10000
    },
    "retries": {
      "serviceHealth": 5,
      "testExecution": 2,
      "networkRequest": 3
    },
    "performance": {
      "maxSummarizationTime": 30000,
      "maxChunkingTime": 60000,
      "maxCacheRetrievalTime": 1000,
      "concurrentRequestLimit": 5
    }
  },
  "testData": {
    "categories": [
      "technical",
      "academic", 
      "research",
      "personal",
      "edge-case",
      "stress-test"
    ],
    "contentSizes": {
      "empty": 0,
      "minimal": "1-50",
      "short": "51-200",
      "medium": "201-1000",
      "long": "1001-5000",
      "extraLong": "5001+"
    },
    "expectedBehaviors": {
      "empty": "error",
      "minimal": "summary_or_error",
      "short": "summary",
      "medium": "summary",
      "long": "summary_with_chunking",
      "extraLong": "summary_with_chunking"
    }
  },
  "testScenarios": {
    "smoke": [
      "basic_summarization",
      "error_handling_empty_content",
      "service_health_checks"
    ],
    "integration": [
      "content_change_detection",
      "summary_editing",
      "data_persistence",
      "caching_behavior"
    ],
    "performance": [
      "long_content_chunking",
      "concurrent_requests",
      "cache_effectiveness",
      "memory_usage"
    ],
    "edge_cases": [
      "special_characters",
      "unicode_content",
      "malformed_input",
      "service_unavailable"
    ]
  },
  "monitoring": {
    "metrics": [
      "response_time",
      "error_rate",
      "cache_hit_ratio",
      "memory_usage",
      "cpu_usage"
    ],
    "alerts": {
      "responseTimeThreshold": 30000,
      "errorRateThreshold": 0.05,
      "memoryUsageThreshold": 0.8
    }
  }
}